{
  "name": "frontend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "frontend",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project frontend --web",
  "targets": {
    "build": {
      "options": {
        "cwd": "apps/frontend",
        "tty": false,
        "command": "next build"
      },
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["default", "^production"],
      "outputs": [
        "{workspaceRoot}/apps/frontend/.next/!(cache)/**/*",
        "{workspaceRoot}/apps/frontend/.next/!(cache)"
      ],
      "executor": "nx:run-commands",
      "configurations": {},
      "parallelism": true
    },
    "dev": {
      "continuous": true,
      "options": {
        "cwd": "apps/frontend",
        "command": "next dev"
      },
      "executor": "nx:run-commands",
      "configurations": {},
      "parallelism": true
    }
  }
}
